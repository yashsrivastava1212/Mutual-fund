# Groq — get your key at https://console.groq.com
GROQ_API_KEY=

# Optional Groq settings
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=120
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.1

# Local embeddings — free BGE models via sentence-transformers (no OpenAI API)
EMBEDDING_PRESET=auto
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# API security
MAX_MESSAGE_LENGTH=2000
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# API server (Railway sets PORT automatically)
API_HOST=0.0.0.0
API_PORT=8000

# Daily scheduler — 10:00 AM IST
SCHEDULER_ENABLED=false
SCHEDULER_HOUR=10
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Kolkata
SCHEDULER_MAX_RETRIES=2
SCHEDULER_RETRY_DELAY_SECONDS=60
